# Kopii ulož jako .env.local

# --- Admin ---
ADMIN_PASSWORD=zmen-me

# --- Info o svatbě (zobrazuje se ve formuláři) ---
WEDDING_COUPLE="Anna & Petr"
WEDDING_DATE=2026-06-20
WEDDING_VENUE="Zámek Loučeň"

# --- Databáze ---
# Lokální vývoj: nech prázdné, použije se ./data/wedding.db
