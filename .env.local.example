TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Email (Resend) ---
# Získáš na https://resend.com → API Keys
RESEND_API_KEY=
# Odesílací adresa. Na MVP start: onboarding@resend.dev
# Po ověření vlastní domény v Resend: např. svatba@tvoje-domena.cz
EMAIL_FROM=onboarding@resend.dev
